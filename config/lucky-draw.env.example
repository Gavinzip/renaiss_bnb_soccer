# Copy to config/lucky-draw.env.local and fill local secrets there.
# Do not commit *.local files.

BSCSCAN_API_URL=https://api.etherscan.io/v2/api
BSCSCAN_CHAIN_ID=56
BSCSCAN_API_KEY=
BSCSCAN_REQUEST_TIMEOUT_MS=30000
LUCKY_DRAW_EVENT_CACHE_LOOKBACK_MINUTES=60

# Football campaign default starts from 2026-07-03 14:00:00 +0800.
# Override the end when the official campaign close time is final.
LUCKY_DRAW_CAMPAIGN_START=1783058400
LUCKY_DRAW_CAMPAIGN_END=1784505600
SOCCER_INSIDER_TICKET_GRANT_PATH=config/soccer-insider-ticket-grants.json
SOCCER_INSIDER_TICKET_ADDRESSES=
SOCCER_INSIDER_PRACTICE_TICKETS=100
SOCCER_INSIDER_GRANT_TICKETS=100

# Backend vote/result inputs for per-match production draw ledgers.
LUCKY_DRAW_BASE_LEDGER_PATH=/data/soccer/lucky-draw-ledger.json
SOCCER_VOTE_STORE=sqlite
SOCCER_VOTE_DB_PATH=/data/soccer/votes/vote-store.sqlite
SOCCER_VOTE_STATE_PATH=/data/soccer/votes/vote-state.json
SOCCER_MATCH_RESULTS_PATH=/data/soccer/match-results.json
SOCCER_MATCH_DRAW_LEDGER_PATH=/data/soccer/match-draw-ledger.json
SOCCER_MATCH_DRAW_LEDGER_URI=/match-draw-ledger.json
SOCCER_DRAW_ALTERNATE_COUNT=2
FIFA_STANDINGS_CACHE_SECONDS=45

# Optional JSON array of extra legacy pack rules:
# [{"pack":"example-pack","label":"Example Pack","ticketWeight":2,"openContract":"0x...","packId":"0x...","buybackContract":"0x..."}]
LUCKY_DRAW_EXTRA_LEGACY_PACKS=
