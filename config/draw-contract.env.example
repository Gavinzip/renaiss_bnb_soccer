# Copy to config/draw-contract.env.local and fill local secrets there.
# Do not commit *.local files.

BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_CHAIN_ID=56
BSC_DEPLOYER_PRIVATE_KEY=

# Binance Oracle VRF on BNB Smart Chain mainnet.
VRF_COORDINATOR=0x9632ADE542f12114f5E5AD4d6F8e47fB993955da
VRF_KEY_HASH=0xcd65a78499993598be303c914c3e37b0103ead6b1f279d1dbfa0ef080e7141a4
VRF_REQUEST_CONFIRMATIONS=3
VRF_CALLBACK_GAS_LIMIT=200000
VRF_NATIVE_FUND_BNB=0.001
VRF_SUBSCRIPTION_ID=

# Constructor default only. Production round reveal uses per-match prizeSlotCount from match-draw-ledger.json.
INITIAL_PRIZE_SLOT_COUNT=20
DRAW_ROUND_ID=round16
DRAW_ROUND_KEY=
DRAW_MATCH_BATCH_SIZE=1

DRAW_CONTRACT_ADDRESS=
DRAW_OWNER_ADDRESS=
DRAW_OPERATOR_ADDRESS=
DRAW_ADMIN_ADDRESSES=
DRAW_ADMIN_API_ENABLED=0

# Round-level draw ledger generated after backend-confirmed official results.
# One VRF random word is requested per round; each match keeps an independent ticket namespace.
LUCKY_DRAW_LEDGER_PATH=/data/soccer/match-draw-ledger.json
SOCCER_DRAW_WINNERS_PATH=/data/soccer/draw-winners.json
SOCCER_DRAW_ALTERNATE_COUNT=2
WINNER_REVEAL_VIDEO_URL=https://pub-7230fa99c50e44e9b241e47cac526165.r2.dev/draw/winner-reveal-2026-06-17-hq.mp4
