# Copy to config/draw-contract.sandbox.env.local. Do not commit the .local file.
# This is a BNB Chain MAINNET smoke-test contract. It must use a new contract
# address and a different VRF subscription from the official draw contract.

BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_CHAIN_ID=56
BSC_DEPLOYER_PRIVATE_KEY=

VRF_COORDINATOR=0x9632ADE542f12114f5E5AD4d6F8e47fB993955da
VRF_KEY_HASH=0xcd65a78499993598be303c914c3e37b0103ead6b1f279d1dbfa0ef080e7141a4
VRF_REQUEST_CONFIRMATIONS=3
VRF_CALLBACK_GAS_LIMIT=200000
VRF_NATIVE_FUND_BNB=0.002
VRF_SUBSCRIPTION_ID=

# The sandbox reads a byte-for-byte copy of an official locked round. This value
# must match the source locked snapshot selected by the operator.
INITIAL_PRIZE_SLOT_COUNT=1
DRAW_ROUND_ID=semiFinal
DRAW_MATCH_BATCH_SIZE=1

DRAW_CONTRACT_ADDRESS=
DRAW_OWNER_ADDRESS=
DRAW_OPERATOR_ADDRESS=
DRAW_ADMIN_ADDRESSES=
DRAW_ADMIN_API_ENABLED=0

LUCKY_DRAW_LEDGER_PATH=/data/soccer/draw-sandbox/match-draw-ledger.json
SOCCER_DRAW_WINNERS_PATH=/data/soccer/draw-sandbox/draw-winners.json
SOCCER_DRAW_WINNERS_HISTORY_DIR=/data/soccer/draw-sandbox/draw-winners-history
