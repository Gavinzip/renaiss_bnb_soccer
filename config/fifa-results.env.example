# Copy to config/fifa-results.env.local and fill production paths.
# Do not commit *.local files.

FIFA_API_BASE_URL=https://api.fifa.com/api/v3
FIFA_RESULTS_SOURCE_MAP_PATH=/data/soccer/fifa-match-map.json
SOCCER_MATCH_RESULTS_PATH=/data/soccer/match-results.json

# Required only when a source-map row uses fifaMatchNumber instead of fifaMatchId.
FIFA_RESULTS_FROM=2026-06-29
FIFA_RESULTS_TO=2026-07-20
FIFA_RESULTS_REQUEST_TIMEOUT_MS=30000

# Production server background sync controls.
FIFA_RESULT_SYNC_ENABLED=1
FIFA_RESULT_SYNC_ON_STARTUP=1
FIFA_RESULT_SYNC_MINUTES=10
FIFA_RESULT_SYNC_HISTORY_LIMIT=24
