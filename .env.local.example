# Copy this file to .env.local for local testing. Do not commit .env.local.
# If SOCCER_RUNTIME_TARGET is not set, the server defaults to the production/server paths.

SOCCER_RUNTIME_TARGET=local
PORT=3000
# Switch this between .local-data/soccer-production and .local-data/soccer-test-batch.
SOCCER_LOCAL_DATA_DIR=.local-data/soccer-production
SOCCER_PRODUCTION_API_ORIGIN=https://renaiss-worldcup.zeabur.app
# Optional, only if production read APIs are later protected.
SOCCER_PRODUCTION_API_BEARER_TOKEN=

VITE_LOCAL_API_ORIGIN=http://127.0.0.1:3000
VITE_LEDGER_SUMMARY_URL=/api/raffle-summary
VITE_LEDGER_ENTRY_URL=/api/raffle-entry
VITE_MILESTONE_SUMMARY_URL=/api/milestones
VITE_VOTE_PREVIEW_URL=/api/vote-preview
VITE_VOTE_SUBMIT_URL=/api/votes
VITE_AUTH_ME_URL=/api/auth/me
VITE_MATCH_RESULTS_URL=/api/match-results
VITE_DRAW_WINNERS_URL=/api/draw-winners
VITE_WINNER_REVEAL_VIDEO_URL=https://pub-7230fa99c50e44e9b241e47cac526165.r2.dev/draw/winner-reveal-2026-06-17-hq.mp4
VITE_GA_MEASUREMENT_ID=

SOCCER_DATA_DIR=.local-data/soccer-production
LUCKY_DRAW_DATA_DIR=.local-data/soccer-production
LUCKY_DRAW_CACHE_DIR=.local-data/soccer-production/cache
LUCKY_DRAW_LEDGER_PATH=.local-data/soccer-production/lucky-draw-ledger.json
LUCKY_DRAW_SNAPSHOT_DIR=.local-data/soccer-production/snapshots
SOCCER_VOTES_DIR=.local-data/soccer-production/votes
SOCCER_VOTE_STORE=sqlite
SOCCER_VOTE_DB_PATH=.local-data/soccer-production/votes/vote-store.sqlite
SOCCER_PROFILE_DB_PATH=.local-data/soccer-production/profiles/user-profiles.sqlite
SOCCER_VOTE_STATE_PATH=.local-data/soccer-production/votes/vote-state.json
SOCCER_VOTE_PREVIEW_PATH=.local-data/soccer-production/votes/vote-preview.json
SOCCER_MATCH_RESULTS_PATH=.local-data/soccer-production/match-results.json
SOCCER_MATCH_DRAW_LEDGER_PATH=.local-data/soccer-production/match-draw-ledger.json
SOCCER_MATCH_DRAW_LEDGER_URI=/match-draw-ledger.json
SOCCER_DRAW_WINNERS_PATH=.local-data/soccer-production/draw-winners.json
SOCCER_DRAW_ALTERNATE_COUNT=2
WINNER_REVEAL_VIDEO_URL=https://pub-7230fa99c50e44e9b241e47cac526165.r2.dev/draw/winner-reveal-2026-06-17-hq.mp4

# Local mode should not poll BscScan/FIFA or restore/push backup data automatically.
LUCKY_DRAW_REFRESH_ENABLED=0
LUCKY_DRAW_REFRESH_ON_STARTUP=0
FIFA_RESULT_SYNC_ENABLED=0
FIFA_RESULT_SYNC_ON_STARTUP=0
DATA_BACKUP_ENABLED=0
DATA_BACKUP_RESTORE_ON_STARTUP=0

# Local auth. Put your own OAuth app values here.
PUBLIC_APP_ORIGIN=http://127.0.0.1:3000
AUTH_PUBLIC_ORIGIN=http://127.0.0.1:3000
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
LOGIN_AUDIT_HASH_SECRET=replace-with-at-least-32-random-characters
AUTH_REQUIRE_SESSION_FOR_VOTES=0
AUTH_COOKIE_SECURE=0
AUTH_SUCCESS_REDIRECT_PATH=/?auth=success
AUTH_ERROR_REDIRECT_PATH=/?auth=error

RENAISS_ISSUER=https://www.renaiss.xyz/api/auth
RENAISS_CLIENT_ID=rpk_u2PA7GjyPDT1c-h81KhRhI2j
RENAISS_CLIENT_SECRET=
RENAISS_REDIRECT_URI=
RENAISS_SCOPE=openid profile email safe x

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/api/auth/google/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:3000/api/auth/discord/callback
DISCORD_OAUTH_SCOPE=identify email

# X OAuth usually allows fewer redirect URLs. Local X login only works if the X app allows the generated localhost callback.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=
X_OAUTH_SCOPE=users.read follows.read offline.access
X_FOLLOW_GATE_HANDLE=thefireflyapp
X_FOLLOW_VERIFY_RETRY_SECONDS=60
X_FOLLOW_GATE_REQUIRED=0
X_FOLLOW_SKIP_ENABLED=1
FIREFLY_X_ACCOUNT_ELIGIBILITY_REQUIRED=0
FIREFLY_RENAISS_API_KEY=
FIREFLY_X_ACCOUNT_ELIGIBILITY_TTL_SECONDS=86400
FIREFLY_X_ACCOUNT_ELIGIBILITY_TIMEOUT_MS=8000

SIWE_DOMAIN=127.0.0.1:3000
SIWE_CHAIN_ID=56
IDENTITY_RESOLVER_API_URL=
IDENTITY_RESOLVER_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_PRODUCT_NAME=Renaiss World Cup Local

# Optional deterministic local draw/test-batch seeds.
SOCCER_LOCAL_DRAW_DEMO_SEED=renaiss-round16-local-demo-2026
SOCCER_TEST_BATCH_DATA_DIR=.local-data/soccer-test-batch
SOCCER_TEST_BATCH_SOURCE_LEDGER_PATH=.local-data/soccer-production/lucky-draw-ledger.json
SOCCER_TEST_BATCH_VOTE_COUNT=1000
SOCCER_TEST_BATCH_PRIZE_SLOTS=2
SOCCER_TEST_BATCH_ALTERNATES=2
SOCCER_TEST_BATCH_SEED=renaiss-round16-test-batch-2026
